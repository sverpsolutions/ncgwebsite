/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model audit_logs {
  id            Int      @id @default(autoincrement())
  module        String   @db.VarChar(50)
  action        String   @db.VarChar(50)
  record_id     Int
  record_no     String?  @db.VarChar(50)
  old_data      String?  @db.Text
  new_data      String?  @db.Text
  old_amount    Decimal? @db.Decimal(12, 2)
  new_amount    Decimal? @db.Decimal(12, 2)
  description   String?  @db.Text
  user_id       Int
  user_name     String?  @db.VarChar(100)
  ip_address    String?  @db.VarChar(45)
  location_id   Int?
  location_name String?  @db.VarChar(100)
  created_at    DateTime @default(now()) @db.DateTime(0)

  @@index([created_at], map: "idx_audit_date")
  @@index([module, record_id], map: "idx_audit_module")
  @@index([user_id], map: "idx_audit_user")
}

